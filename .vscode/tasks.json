{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Deploy locally",
      "type": "shell",
      "command": "python3",
      "args": ["-m", "http.server", "3001"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "problemMatcher": {
        "owner": "serve",
        "pattern": { "regexp": "^(.*)$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "showReuseMessage": false
      },
      "isBackground": true,
      "runOptions": {
        "instanceLimit": 1
      }
    }
  ]
}
